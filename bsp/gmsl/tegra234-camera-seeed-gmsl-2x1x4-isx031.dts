				i2c@c250000{
					mux_cam_i2c1: cam_i2cmux1@70 {
						compatible = "nxp,pca9548";
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <0x70>;
						idle-state = <0>;
						i2c@0{
							#address-cells = <1>;
							#size-cells = <0>;
							reg = <0>;
						};
					};
