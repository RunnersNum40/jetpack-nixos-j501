												physical_h = "12.5";
												
												sensor_model = "isx031";
												
												use_sensor_mode_id = "true";
												
												nv,reg-bits = <16>;
												nv,val-bits = <8>;
												
												nv,chip-id-regs = <0x7e8a 0x7e8b>;
												nv,chip-id-masks = <0xff 0x0f>;
												nv,chip-id-vals = <0x31 0x0>;
												
												nv,wait-ms-cmd = <0x32>;
												
												nv,mode-common-cmd = <
												0x8a01 0x00 /* Stream off */
												0x8af0 0x01
												0xbf14 0x01 /* SW reset */
												>;
												
												nv,start-stream-cmd = <
												0x8a01 0x80 /* Stream on */
												>;
												
												nv,stop-stream-cmd = <0x8a01 0x00>;
												
												
												mode0 {/*ox03a*/
													nv,mode-cmd = <0>;
													mclk_khz = "24000";
													set_mode_delay_ms = "5000";
													num_lanes = "4";
													tegra_sinterface = "serial_g";
													vc_id = "3";
													phy_mode = "DPHY";
													discontinuous_clk = "no";
													dpcm_enable = "false";
													cil_settletime = "0";
													lane_polarity = "0";
													
													active_w = "1920";
													active_h = "1536";
													
													readout_orientation = "0";
													csi_pixel_bit_depth = "16";
													dynamic_pixel_bit_depth = "16";
													mode_type = "yuv";
													pixel_phase = "yuyv";
													line_length = "2200";
													inherent_gain = "1";
													pix_clk_hz = "200000000";
													serdes_link_freq = "1250000000";
													serdes_pix_clk_hz = "625000000";
													
													
													gain_factor = "1000";
													min_gain_val = "1"; /* 1.00x */
													max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
													step_gain_val = "300";
													default_gain = "16"; /* 1.00x */
													
													min_hdr_ratio = "1";
													max_hdr_ratio = "1";
													
													framerate_factor = "1000000";
													min_framerate = "30000000"; /* 30.0 fps */
													max_framerate = "30000000"; /* 30.0 fps */
													step_framerate = "1";
													default_framerate = "30000000"; /* 30.0 fps */
													
													exposure_factor = "1000000";
													min_exp_time = "59"; /* us */
													max_exp_time = "33333"; /* us */
													step_exp_time = "1";
													default_exp_time = "33333"; /* us */
													
													embedded_metadata_height = "0";
												};
												
												mode1 {/*imx390 || ar0233c */
													nv,mode-cmd = <0>;
													mclk_khz = "24000";
													set_mode_delay_ms = "5000";
													num_lanes = "4";
													tegra_sinterface = "serial_g";
													vc_id = "3";
													phy_mode = "DPHY";
													discontinuous_clk = "no";
													dpcm_enable = "false";
													cil_settletime = "0";
													lane_polarity = "0";
													
													active_w = "1920";
													active_h = "1080";
													
													readout_orientation = "0";
													csi_pixel_bit_depth = "16";
													dynamic_pixel_bit_depth = "16";
													mode_type = "yuv";
													pixel_phase = "yuyv";
													line_length = "2200";
													inherent_gain = "1";
													pix_clk_hz = "200000000";
													serdes_link_freq = "1250000000";
													serdes_pix_clk_hz = "625000000";
													gain_factor = "1000";
													min_gain_val = "1"; /* 1.00x */
													max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
													step_gain_val = "300";
													default_gain = "16"; /* 1.00x */
													
													min_hdr_ratio = "1";
													max_hdr_ratio = "1";
													
													framerate_factor = "1000000";
													min_framerate = "30000000"; /* 30.0 fps */
													max_framerate = "30000000"; /* 30.0 fps */
													step_framerate = "1";
													default_framerate = "30000000"; /* 30.0 fps */
													
													exposure_factor = "1000000";
													min_exp_time = "59"; /* us */
													max_exp_time = "33333"; /* us */
													step_exp_time = "1";
													default_exp_time = "33333"; /* us */
													
													embedded_metadata_height = "0";
												};
												mode2 {/* ar0820c */
													nv,mode-cmd = <0>;
													mclk_khz = "24000";
													set_mode_delay_ms = "5000";
													num_lanes = "4";
													tegra_sinterface = "serial_g";
													vc_id = "3";
													phy_mode = "DPHY";
													discontinuous_clk = "no";
													dpcm_enable = "false";
													cil_settletime = "0";
													lane_polarity = "0";
													
													active_w = "3840";
													active_h = "2160";
													
													readout_orientation = "0";
													csi_pixel_bit_depth = "16";
													dynamic_pixel_bit_depth = "16";
													mode_type = "yuv";
													pixel_phase = "yuyv";
													line_length = "2200";
													inherent_gain = "1";
													pix_clk_hz = "200000000";
													
													serdes_link_freq = "1250000000";
													serdes_pix_clk_hz = "625000000";
													
													
													gain_factor = "1000";
													min_gain_val = "1"; /* 1.00x */
													max_gain_val = "30000"; /* 15.5x (16 - 1/16) */
													step_gain_val = "300";
													default_gain = "16"; /* 1.00x */
													
													min_hdr_ratio = "1";
													max_hdr_ratio = "1";
													
													framerate_factor = "1000000";
													min_framerate = "30000000"; /* 30.0 fps */
													max_framerate = "30000000"; /* 30.0 fps */
													step_framerate = "1";
													default_framerate = "30000000"; /* 30.0 fps */
													
													exposure_factor = "1000000";
													min_exp_time = "59"; /* us */
													max_exp_time = "33333"; /* us */
													step_exp_time = "1";
													default_exp_time = "33333"; /* us */
													
													embedded_metadata_height = "0";
												};
												
												ports {
													#address-cells = <1>;
													#size-cells = <0>;
													port@0 {
														reg = <0>;
														
														cam_7_out: endpoint {
															port-index = <0x06>;
															bus-width = <0x04>;
															remote-endpoint = <&ser_7_ch_3_in>;
															data-lanes = <1 2 3 4>;
															clock-lanes = <0>;
														};
													};
												};
											};
											
										};
									};
									
									pipe@0 {
										reg = <0>;
										maxim,stream-id = <0x03>;
										maxim,dbl8;
										maxim,soft-bpp = <0x10>;
									};
									
									channel@0 {
										reg = <0>;
										
										label = "ser_7_ch_3";
										
										ports {
											#address-cells = <1>;
											#size-cells = <0>;
											
											port@0 {
												reg = <0>;
												
												ser_7_ch_3_out: endpoint {
													remote-endpoint = <&des_1_ch_3_in>;
												};
											};
											
											port@1 {
												reg = <1>;
												
												ser_7_ch_3_in: endpoint {
													remote-endpoint = <&cam_7_out>;
												};
											};
										};
									};
									
									ser_7_pins: pins {
										
										ser_7_mfp4_rclk {
											pins = "mfp4";
											function = "rclkout";
											maxim,rclkout-clock = <0>;
										};
										
										ser_7_mfp0_pwdn {
											pins = "mfp0";
											function = "gpio";
											output-high;
											output-enable;
										};
										
										ser_7_mfp7_fsync {
											pins = "mfp7";
											function = "gpio";
											output-high;
											input-disable;
										};
									};
									
									
								};
							};
							
						};
					};
					
					
				};
				
				
			};
			
			tegra-capture-vi {
				num-channels = <8>;
				
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					
					port@0 {
						reg = <0>;
						
						vi_in0: endpoint {
							vc-id = <0>;
							port-index = <0x02>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_0_out>;
						};
					};
					
					port@1 {
						reg = <1>;
						
						vi_in1: endpoint {
							vc-id = <1>;
							port-index = <0x02>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_1_out>;
						};
					};
					
					port@2 {
						reg = <2>;
						
						vi_in2: endpoint {
							vc-id = <2>;
							port-index = <0x02>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_2_out>;
						};
					};
					
					port@3 {
						reg = <3>;
						
						vi_in3: endpoint {
							vc-id = <3>;
							port-index = <0x02>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_3_out>;
						};
					};
					
					
					port@4 {
						reg = <4>;
						
						vi_in4: endpoint {
							vc-id = <0>;
							port-index = <0x05>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_4_out>;
						};
					};
					
					port@5 {
						reg = <5>;
						
						vi_in5: endpoint {
							vc-id = <1>;
							port-index = <0x05>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_5_out>;
						};
					};
					
					port@6 {
						reg = <6>;
						
						vi_in6: endpoint {
							vc-id = <2>;
							port-index = <0x05>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_6_out>;
						};
					};
					
					port@7 {
						reg = <7>;
						
						vi_in7: endpoint {
							vc-id = <3>;
							port-index = <0x05>;
							bus-width = <0x04>;
							remote-endpoint = <&csi_7_out>;
						};
					};
					
					
				};
				
			};
			
			tcp: tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				/**
				* Physical settings to calculate max ISO BW
				*
				* num_csi_lanes = <>;
				* Total number of CSI lanes when all cameras are active
				*
				* max_lane_speed = <>;
				* Max lane speed in Kbit/s
				*
				* min_bits_per_pixel = <>;
				* Min bits per pixel
				*
				* vi_peak_byte_per_pixel = <>;
				* Max byte per pixel for the VI ISO case
				*
				* vi_bw_margin_pct = <>;
				* Vi bandwidth margin in percentage
				*
				* max_pixel_rate = <>;
				* Max pixel rate in Kpixel/s for the ISP ISO case
				*
				* isp_peak_byte_per_pixel = <>;
				* Max byte per pixel for the ISP ISO case
				*
				* isp_bw_margin_pct = <>;
				* Isp bandwidth margin in percentage
				*/
				num_csi_lanes = <0x04>;
				max_lane_speed = <4000000>;
				min_bits_per_pixel = <10>;
				vi_peak_byte_per_pixel = <2>;
				vi_bw_margin_pct = <25>;
				max_pixel_rate = <240000>;
				isp_peak_byte_per_pixel = <5>;
				isp_bw_margin_pct = <25>;
				
				nv,proc-device-tree-paths ="cam_0", "cam_1", "cam_2", "cam_3", "cam_4", "cam_5", "cam_6", "cam_7";
				nv,proc-device-tree-targets = <&cam_0 &cam_1 &cam_2 &cam_3 &cam_4 &cam_5 &cam_6 &cam_7>;
				
				/**
				* The general guideline for naming badge_info contains 3 parts, and is as follows,
				* The first part is the camera_board_id for the module; if the module is in a FFD
				* platform, then use the platform name for this part.
				* The second part contains the position of the module, ex. "rear" or "front".
				* The third part contains the last 6 characters of a part number which is found
				* in the module's specsheet from the vendor.
				*/
				modules {
					
					module0 {
						badge = "jakku_front_camera0";
						position = "topleft";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_0";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_0";
						};
					};
					
					module1 {
						badge = "jakku_front_camera1";
						position = "topright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_1";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_1";
						};
					};
					
					module2 {
						badge = "jakku_front_camera2";
						position = "bottomleft";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_2";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_2";
						};
					};
					
					module3 {
						badge = "jakku_front_camera3";
						position = "bottomright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_3";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_3";
						};
					};
					
					module4 {
						badge = "jakku_front_camera4";
						position = "topleft";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_4";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_4";
						};
					};
					
					module5 {
						badge = "jakku_front_camera5";
						position = "topright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_5";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_5";
						};
					};
					
					module6 {
						badge = "jakku_front_camera6";
						position = "bottomleft";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_6";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_6";
						};
					};
					
					module7 {
						badge = "jakku_front_camera7";
						position = "bottomright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							devname = "cam_7";
							proc-device-tree = "/proc/device-tree/tegra-camera-platform/cam_7";
						};
					};
				};
			};
			
			
		};
	};
};




