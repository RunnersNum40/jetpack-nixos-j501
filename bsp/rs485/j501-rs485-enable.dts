// SPDX-License-Identifier: GPL-2.0-only
//
// J501 Mini RS485 (JST J8, /dev/ttyTHS4) bring-up via GPIO hogs.
//
// The onboard RS485 transceiver + its 120R termination are gated by two GPIOs
// that must be held low (Seeed reComputer J501 Mini wiki, "RS485"):
//   gpioset 0 126=0  -> RS485 transceiver enable  (gpiochip0 line 126 = PY.04)
//   gpioset 1 9=0    -> 120R termination enable    (gpiochip1 line 9   = PBB.01)
//
// IMPORTANT: a gpio-hog's `gpios` cell is the DT specifier
// TEGRA234_{MAIN,AON}_GPIO(port, pin) = port_index*8 + pin — a SPARSE scheme
// (8 slots per port regardless of populated pins). This is NOT the dense
// libgpiod/`gpioset` line offset. They diverge on the main controller:
//   PY.04  = MAIN(Y=23, 4) = 188   (libgpiod line 126)
//   PBB.01 = AON (BB=1, 1) = 9     (libgpiod line 9 — aon early ports are full)
// Port indices verified against working DT refs: MAIN(H,6)=62=PH.06 (GMSL reset),
// MAIN(Q,6)=126=PQ.06 (observed when this hog wrongly used <126>).
//
// Fragments target the controllers by path (not &phandle): the Jetson
// bootloader that applies OVERLAY_DTB_FILE does not resolve __fixups__.

/dts-v1/;
/plugin/;

/ {
	overlay-name = "J501 Mini RS485 enable + termination (gpio hogs)";

	fragment@0 {
		target-path = "/bus@0/gpio@2200000";
		__overlay__ {
			rs485-enable-hog {
				gpio-hog;
				gpios = <188 0>; /* MAIN(Y,4)=PY.04; 0=ACTIVE_HIGH, output-low = phys 0 */
				output-low;
				line-name = "rs485-enable";
			};
		};
	};

	fragment@1 {
		target-path = "/bus@0/gpio@c2f0000";
		__overlay__ {
			rs485-term-hog {
				gpio-hog;
				gpios = <9 0>; /* AON(BB,1)=PBB.01; 0=ACTIVE_HIGH, output-low = phys 0 */
				output-low;
				line-name = "rs485-term";
			};
		};
	};
};
