+/*
+ * RS-485 DE (direction) control, matching Seeed's serial-tegra driver: the DT
+ * rs485-de-gpios stays ACTIVE_LOW, and the driver inverts (assert/transmit =
+ * logical 0 -> physical high; deassert/receive = logical 1 -> physical low).
+ */
+static inline void tegra_uart_rs485_de_assert(struct tegra_uart_port *tup)
+{
+	if (tup->rs485_de_gpio)
+		gpiod_set_value(tup->rs485_de_gpio, 0);
+}
+
+static inline void tegra_uart_rs485_de_deassert(struct tegra_uart_port *tup)
+{
+	if (tup->rs485_de_gpio)
+		gpiod_set_value(tup->rs485_de_gpio, 1);
+}
+
+static enum hrtimer_restart tegra_uart_rs485_de_expire(struct hrtimer *t)
+{
+	struct tegra_uart_port *tup =
+		container_of(t, struct tegra_uart_port, rs485_de_timer);
+
+	if (tegra_uart_read(tup, UART_LSR) & UART_LSR_TEMT) {
+		tegra_uart_rs485_de_deassert(tup);
+		return HRTIMER_NORESTART;
+	}
+	hrtimer_forward_now(t, ns_to_ktime(10000));
+	return HRTIMER_RESTART;
+}
+
